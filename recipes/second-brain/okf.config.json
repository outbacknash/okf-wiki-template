{
  "bundleRoot": ".",
  "ignore": [
    "node_modules/**",
    ".git/**",
    "README.md"
  ],
  "okfVersion": "0.1",
  "types": [
    "note",
    "project",
    "area",
    "resource",
    "person"
  ],
  "rules": {
    "frontmatter-parseable": "error",
    "type-present": "error",
    "index-frontmatter": "error",
    "okf-version": "warn",
    "log-structure": "warn",
    "type-known": "warn",
    "title-present": "warn",
    "description-present": "warn",
    "timestamp-present": "warn",
    "timestamp-iso8601": "warn",
    "no-wikilinks": "warn",
    "broken-link": "warn"
  }
}
